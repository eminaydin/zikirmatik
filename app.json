{
  "expo": {
    "name": "Zikirmatik",
    "slug": "zikirmatik",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "zikirmatik",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.emindev.zikirmatik",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.emindev.zikirmatik",
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/icon.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f4e1fabc-5478-40b5-8655-f35c6d05a724"
      }
    }
  }
}